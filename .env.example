# ============================================================================
# API Bridge Bot - variaveis de ambiente (TEMPLATE)
# Copie para .env e preencha. O .env e ignorado pelo git (nunca comite segredos).
# Carregado pelos scripts scripts/run-local.ps1 / scripts/run-local.sh.
# Toda config abaixo tem default no application.yml; aqui voce sobrescreve.
# ============================================================================

# --- Telegram (obrigatorio para enviar) ---
# Token do bot criado no BotFather. NUNCA comite este valor.
TELEGRAM_BOT_TOKEN=
# Chat destino padrao (quando a integracao nao define chatId proprio).
TELEGRAM_DEFAULT_CHAT=
# Base da Bot API (troque so para apontar a um mock em testes manuais).
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_TIMEOUT=3s
TELEGRAM_RETRY_MAX_ATTEMPTS=2
TELEGRAM_RETRY_BACKOFF=300ms

# --- Redis (opcional; o app degrada para SQLite se ausente) ---
REDIS_HOST=localhost
REDIS_PORT=6379
DEDUP_TTL=24h

# --- Banco (SQLite por padrao) ---
DATABASE_URL=jdbc:sqlite:data/database.db

# --- Scheduler / execucao ---
APP_SCHEDULER_ENABLED=true
POLLING_THREADS=5

# --- Logs ---
ROOT_LOG_LEVEL=INFO
LOG_LEVEL=DEBUG
